# ============================================
# CARLOPHILLIPS - ENVIRONMENT CONFIGURATION
# ============================================

# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=carlophillips

# Application URLs
NEXT_PUBLIC_BASE_URL=https://carlo-minimal.preview.emergentagent.com
CORS_ORIGINS=*

# ============================================
# SHOPIFY STOREFRONT API CONFIGURATION
# ============================================
#
# The Shopify Storefront API allows you to build custom storefronts
# that fetch products, collections, and handle cart/checkout.
#
# HOW TO GET YOUR CREDENTIALS:
# ----------------------------
# 1. Log into your Shopify Admin: https://admin.shopify.com
# 2. Go to: Settings > Apps and sales channels
# 3. Click "Develop apps" (enable if needed)
# 4. Click "Create an app" - name it "Carlophillips Storefront"
# 5. Go to "Configuration" tab
# 6. Under "Storefront API", click "Configure"
# 7. Enable these scopes:
#    ✓ unauthenticated_read_product_listings
#    ✓ unauthenticated_read_product_inventory
#    ✓ unauthenticated_read_product_tags
#    ✓ unauthenticated_write_checkouts
#    ✓ unauthenticated_read_checkouts
#    ✓ unauthenticated_read_content
# 8. Click "Save"
# 9. Go to "API credentials" tab
# 10. Click "Install app"
# 11. Copy "Storefront API access token" - this is your token
#
# SECURITY NOTE:
# --------------
# The Storefront API token is SAFE to expose in frontend code.
# It only allows read access and checkout creation.
# NEVER expose your Admin API token in frontend code.
#
# ============================================

# Your Shopify store domain (without https://)
# Example: my-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=

# Shopify Storefront API Access Token
# Get this from: Shopify Admin > Settings > Apps > Your App > API credentials
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# ============================================
# OPTIONAL: ANALYTICS & MARKETING
# ============================================

# Google Analytics 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel
# NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# ============================================
# OPTIONAL: EMAIL MARKETING (Klaviyo)
# ============================================

# NEXT_PUBLIC_KLAVIYO_PUBLIC_API_KEY=
