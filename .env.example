# Public site configuration
NEXT_PUBLIC_BASE_URL=
CORS_ORIGINS=

# Shopify Storefront API only. Use dev/test store values for local and preview.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Server-side secrets. Never prefix these with NEXT_PUBLIC_.
SHOPIFY_ADMIN_API_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SIGNING_SECRET=
REVALIDATION_SECRET=

# Optional data store
MONGO_URL=
DB_NAME=

# Optional newsletter sink. Server-side only; do not prefix with NEXT_PUBLIC_.
GOOGLE_SHEETS_WEBHOOK_URL=
